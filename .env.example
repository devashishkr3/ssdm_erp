# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# Database connection URL.
# Replace with your local or remote database URL.
DATABASE_URL="postgresql://user:password@localhost:5432/ssdm_erp"

# Better Auth Secret.
# Hint: You can generate a strong secret using the command: `openssl rand -base64 32`
BETTER_AUTH_SECRET="your_better_auth_secret_here"
BETTER_AUTH_URL=http://localhost:3000 # Base URL of your app

COLLEGE_NAME="SANT SANDHYA DAS MAHILA COLLEGE"
COLLEGE_ADDRESS="BARH"
COLLEGE_CITY="PATNA"
COLLEGE_STATE="BIHAR"
COLLEGE_PINCODE="000000"
COLLEGE_EMAIL="ssdm@gmail.com"
COLLEGE_PHONE="XXXXXXXXXX"

# Cloudnary data
# Retrieve these from your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME="your_cloud_name_here"
CLOUDINARY_API_KEY="your_api_key_here"
CLOUDINARY_API_SECRET="your_api_secret_here"
CLOUDINARY_URL="cloudinary://your_api_key_here:your_api_secret_here@your_cloud_name_here"

# SuperAdmin Credentials
# Set these to establish your initial superadmin user.
SUPERADMIN_EMAIL="admin@ssdm.com"
SUPERADMIN_PASSWORD="your_superadmin_password_here"

# Payment Gateway Credentials (Getepay)
# Obtain these from your Getepay merchant dashboard.
GETEPAY_MID="your_getepay_mid_here"
GETEPAY_TERMINAL_ID="your_getepay_terminal_id_here"
# Hint: If you need a random base64 key, you could use `openssl rand -base64 32` or similar depending on Getepay requirements.
GETEPAY_KEY="your_getepay_key_here"
GETEPAY_IV="your_getepay_iv_here"
GETEPAY_URL=https://pay1.getepay.in:8443/getepayPortal/pg/v2/generateInvoice

CRYPTO_CODE=10

# Secret code for accessing the Miscellaneous Payment page
MISC_PAYMENT_SECRET_CODE="your_secret_code_here"
NEXT_PUBLIC_APP_URL=http://localhost:3000
GETEPAY_RETURN_URL=http://localhost:3000/api/payments/redirect
GETEPAY_CALLBACK_URL=http://localhost:3000/api/payments/callback